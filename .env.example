# 小肖记账环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# 应用监听配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库类型：sqlite / postgres / mysql
DB_TYPE=sqlite

# SQLite 默认文件库，不需要下面这些配置
# DB_SQLITE_PATH=data/accounting.db

# PostgreSQL 示例
# DB_TYPE=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=accounting
# DB_USER=accounting_user
# DB_PASSWORD=请改成强密码

# MySQL 示例
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=accounting
# DB_USER=accounting_user
# DB_PASSWORD=请改成强密码
